# ── Server ──
PORT=5000
NODE_ENV=development

# ── MongoDB ──
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ──
# Must be at least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# ── Discord OAuth2 ──
# Only these Discord user IDs may sign in to the admin.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5000/api/auth/discord/callback
ALLOWED_DISCORD_IDS=comma,separated,discord,user,ids

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=bean-portfolio

# ── Clients ──
# Where the admin UI lives; OAuth redirects back here.
CLIENT_URL=http://localhost:5174
# Every browser origin allowed to call this API (admin UI + public site).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
